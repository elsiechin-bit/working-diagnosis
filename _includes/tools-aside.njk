<details class="tools-aside" data-pagefind-ignore>
  <summary class="tools-aside__trigger">
    <div>
      <p class="aside-kicker">{{ tools.kicker }}</p>
      <p class="aside-title">{{ tools.label }}</p>
    </div>
    <span class="tools-aside__chevron">▼</span>
  </summary>

  <div class="tools-aside__body">
    {% for category in tools.categories %}
    <details class="tools-group">
      <summary>
        <span class="tools-group__header">{{ category.name }}</span>
      </summary>
      <ul class="tools-list">
        {% for item in category.items %}
        <li>
          <a href="{{ item.url }}">
            <strong>{{ item.name }}</strong>
          </a>
          <p>{{ item.blurb }}</p>
        </li>
        {% endfor %}
      </ul>
    </details>
    {% endfor %}
  </div>
</details>
