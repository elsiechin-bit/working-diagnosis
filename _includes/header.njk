<header class="masthead">
  <div class="wrap masthead-row">
    <a href="/" class="brand">
      <span class="brand-name">Working <em>Diagnosis</em>.</span>
    </a>
    <nav class="primary-nav" aria-label="Primary">

      <details class="nav-drop nav-drop--library">
        <summary>Library</summary>
        <div class="nav-drop-panel">
          <ul class="nav-drop-list">
            {% for item in site.nav %}{% if item.row and item.row < 6 %}
              <li><a href="{{ item.url }}">{{ item.label }}</a></li>
            {% endif %}{% endfor %}
          </ul>
        </div>
      </details>

      <details class="nav-drop nav-drop--workbench">
        <summary>Workbench</summary>
        <div class="nav-drop-panel nav-drop-panel--wide">

          <a href="/workshop/guidelines/" class="nav-drop-feature">
            <span class="nav-drop-feature__label">Reference</span>
            <span class="nav-drop-feature__title">Guideline Comparisons</span>
            <span class="nav-drop-feature__blurb">NZ vs AU vs international across 12 primary care topics.</span>
          </a>

          {% for cat in tools.categories %}
            <details class="nav-drop-cat">
              <summary class="nav-drop-cat__header">{{ cat.name }}</summary>
              <ul class="nav-drop-cat__list">
                {% for tool in cat.items %}
                  <li>
                    <a href="{{ tool.url }}" class="nav-drop-tool">
                      <span class="nav-drop-tool__name">{{ tool.name }}</span>
                      {% if tool.blurb %}<span class="nav-drop-tool__blurb">{{ tool.blurb }}</span>{% endif %}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            </details>
          {% endfor %}

        </div>
      </details>

      <a href="/workshop/" class="nav-room-link nav-room-link--workshop">Workshop</a>

      <span class="nav-utilities">
        {% for item in site.nav %}{% if item.row == 6 and item.inMasthead and not item.divider %}
          <a href="{{ item.url }}"{% if item.group %} class="nav-{{ item.group }}"{% endif %}>{{ item.shortLabel or item.label }}</a>
        {% endif %}{% endfor %}
      </span>

    </nav>
    <button id="search-trigger" class="search-trigger" aria-label="Search site">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.4"/>
        <line x1="9.5" y1="9.5" x2="13" y2="13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      <span>Search</span>
      <kbd>&#x2318;K</kbd>
    </button>
  </div>
</header>
