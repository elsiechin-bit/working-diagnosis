<header class="masthead">
  <div class="wrap masthead-row">
    <a href="/" class="brand">
      <span class="brand-name"><span class="brand-working">Working</span> <em>Diagnosis</em>.</span>
    </a>
    <nav class="primary-nav" aria-label="Primary">

      {# Main sections #}
      {% for item in site.nav %}{% if item.inMasthead and item.group == "section" %}
        <a href="{{ item.url }}" class="primary-nav-link">{{ item.label }}</a>
      {% endif %}{% endfor %}

      {# Specialties dropdown #}
      <details class="nav-drop nav-drop--specialties">
        <summary>Specialties</summary>
        <div class="nav-drop-panel">
          <ul class="nav-drop-list">
            {% for item in site.nav %}{% if item.group == "specialty" %}
              <li><a href="{{ item.url }}"{% if item.inMasthead %} class="featured"{% endif %}>{{ item.label }}</a></li>
            {% endif %}{% endfor %}
          </ul>
        </div>
      </details>

      {# Utility links #}
      {% for item in site.nav %}{% if item.inMasthead and item.group == "utility" %}
        <a href="{{ item.url }}" class="primary-nav-link">{{ item.label }}</a>
      {% endif %}{% endfor %}

    </nav>
    <button id="search-trigger" class="search-trigger" aria-label="Search site">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.4"/>
        <line x1="9.5" y1="9.5" x2="13" y2="13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      <span>Search</span>
      <kbd>&#x2318;K</kbd>
    </button>
  </div>
</header>
