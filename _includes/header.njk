<header class="ed-masthead">
  <div class="ed-masthead-top">
    <a href="/" class="ed-brand">
      Working <em>Diagnosis</em><span class="ed-brand-dot">.</span>
    </a>
    <p class="ed-masthead-tagline">An internet workshop for general practice&nbsp;·&nbsp;Aotearoa</p>
    <div class="ed-masthead-actions">
      <a href="https://ko-fi.com/chilipress" class="ed-coffee-link" target="_blank" rel="noopener noreferrer">
        <span>☕</span><span>Buy me a coffee</span>
      </a>
      <span class="ed-masthead-sep" aria-hidden="true"></span>
      <a href="mailto:chilipress@workingdiagnosis.xyz" class="ed-email-link">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="1.5"/><path d="M3 7l9 6 9-6"/></svg>
        Email
      </a>
      <span class="ed-masthead-sep" aria-hidden="true"></span>
      <button type="button" class="ed-search-btn search-trigger" id="search-open" aria-label="Open search" aria-expanded="false" aria-controls="search-dropdown">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
        Search
        <kbd>⌘K</kbd>
      </button>
    </div>
  </div>

  <nav class="ed-nav" aria-label="Main navigation">
    <a href="/topics/"{% if page.url.startsWith("/topics/") %} class="is-current"{% endif %}>Topics</a>
    <a href="/guidelines/"{% if page.url.startsWith("/guidelines/") %} class="is-current"{% endif %}>Guidelines</a>
    <a href="/medications/"{% if page.url.startsWith("/medications/") %} class="is-current"{% endif %}>Medications</a>
    <a href="/calculators/"{% if page.url.startsWith("/calculators/") %} class="is-current"{% endif %}>Calculators</a>
    <a href="/explainers/"{% if page.url.startsWith("/explainers/") %} class="is-current"{% endif %}>Explainers</a>
    <a href="/patient-tools/handouts-by-specialty/"{% if page.url.startsWith("/patient-tools/handouts-by-specialty/") %} class="is-current"{% endif %}>Handouts</a>
    <a href="/beyond-the-clinic/essays/"{% if page.url.startsWith("/beyond-the-clinic/essays/") %} class="is-current"{% endif %}>Essays</a>
    <a href="/resources/"{% if page.url.startsWith("/resources/") %} class="is-current"{% endif %}>Resources</a>
    <a href="/about/"{% if page.url.startsWith("/about/") %} class="is-current"{% endif %}>About</a>
  </nav>
</header>
