{%- if ticker.items and ticker.items.length -%}
<div class="ticker-bar" aria-label="Recent NZ GP updates">
  <span class="ticker-tag">Updates</span>
  <div class="ticker-overflow">
    <div class="ticker-track">
      {%- for item in ticker.items -%}
      <span class="ticker-item">
        <span class="ticker-source">{{ item.source }}</span>
        <a href="{{ item.url }}" class="ticker-link" target="_blank" rel="noopener noreferrer">{{ item.text }}</a>
      </span>
      {%- endfor -%}
      {# Duplicate for seamless loop  -  aria-hidden so screen readers skip the repeat #}
      {%- for item in ticker.items -%}
      <span class="ticker-item" aria-hidden="true">
        <span class="ticker-source">{{ item.source }}</span>
        <a href="{{ item.url }}" class="ticker-link" tabindex="-1">{{ item.text }}</a>
      </span>
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}
