---
layout: base.njk
---

<article class="topic">
  <header class="topic-header">
    {% if pillar %}<p class="pillar-label">{{ pillar }}</p>{% endif %}
    <h1>{{ title }}</h1>
    {% if description %}<p class="topic-dek">{{ description }}</p>{% endif %}
    {% if pillar or audience %}<p class="audience-tag">{{ audience if audience else "For clinicians" }}</p>{% endif %}
  </header>

  <div class="topic-body">
    {{ content | safe }}
  </div>

  {% if pillar %}
  <aside class="topic-handouts">
    <p><a href="/handouts/#{{ pillar | slugify }}">Patient handouts for {{ pillar }} →</a></p>
  </aside>
  {% endif %}
</article>