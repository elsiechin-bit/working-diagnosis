---
layout: base.njk
hasToc: true
---

<article class="topic">
  <header class="topic-header">

    {% if pageType == "handout" and page.fileSlug != "handouts" %}
    <a class="handout-pdf-link" href="/handouts/{{ page.fileSlug }}/{{ page.fileSlug }}.pdf" download>
      <span class="handout-pdf-link-icon" aria-hidden="true">↓</span>
      <span class="handout-pdf-link-label">PDF version</span>
    </a>
    {% endif %}

    {% if pageType %}<span class="page-type-badge page-type-{{ pageType | slugify }}">{{ pageType }}</span>{% endif %}
    {% if pillar %}<p class="pillar-label">{{ pillar }}</p>{% endif %}

    {% if ctags %}
    <div class="tag-row">
      {% for tag in ctags %}<span class="content-tag tag-{{ tag }}">{{ tag | tagLabel }}</span>{% endfor %}
    </div>
    {% endif %}

    {% if changes %}
    <div class="changes-block">
      <p class="changes-label">What changed{% if changes_date %} - {{ changes_date }}{% endif %}</p>
      <ul class="changes-list">
        {% for change in changes %}<li>{{ change | safe }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}

    <h1>{{ title }}</h1>
    {% if dek %}<p class="topic-dek">{{ dek }}</p>{% endif %}

    <div class="topic-meta">
      {% if date %}<time datetime="{{ date | dateISO }}">{{ date | dateDisplay }}</time>{% endif %}
      <span class="reading-time">{{ content | readingTime }}</span>
    </div>

  </header>

  <div class="topic-body">
    {{ content | safe }}
  </div>

  {% if sources %}
  <section class="topic-sources" data-pagefind-ignore>
    <h2>Sources</h2>
    <ol class="sources-list">
      {% for s in sources %}<li>{{ s | safe }}</li>{% endfor %}
    </ol>
  </section>
  {% endif %}
</article>
