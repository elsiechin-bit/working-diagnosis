---
layout: base.njk
pageType: tool
---

<article class="tool-page">
  <header class="tool-header">
    {% if pillar %}<p class="pillar-label">{{ pillar }}</p>{% endif %}
    <h1>{{ title }}</h1>
    {% if description %}<p class="topic-dek">{{ description }}</p>{% endif %}
  </header>

  <div class="tool-body">
    {{ content | safe }}
  </div>
</article>
