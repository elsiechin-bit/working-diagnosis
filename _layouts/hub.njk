<!doctype html>
<html lang="en-NZ">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}  -  {{ site.title }}</title>
  <meta name="description" content="{{ description or site.tagline }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300..700;1,8..60,300..700&family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Newsreader:ital,opsz,wght@0,6..72,300..800;1,6..72,300..800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css">
</head>
<body class="hub-page">

  {% include "header.njk" %}

  <div class="hub-layout">

    {# ── Hero ───────────────────────────────────────────────────── #}
    <section class="hub-hero">
      <div class="hub-hero-main">
        <nav class="hub-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Working Diagnosis</a>
          <span aria-hidden="true">/</span>
          <span class="hub-breadcrumb-current">{{ title }}</span>
        </nav>
        <h1 class="hub-title">{{ title }}<span class="hub-title-dot">.</span></h1>
        <p class="hub-lede">{{ lede }}</p>
      </div>
      <aside class="hub-glance" aria-label="At a glance">
        <p class="hub-eyebrow">At a glance</p>
        <div class="hub-glance-items">
          {% for cat in categories %}
          <div class="hub-glance-item{% if loop.first %} is-first{% endif %}">
            <a href="/{{ hubSlug }}/{{ cat.slug }}/" class="hub-glance-link">{{ cat.title }}</a>
          </div>
          {% endfor %}
        </div>
      </aside>
    </section>

    {# ── Prev / next strip ──────────────────────────────────────── #}
    {% if prevHub or nextHub %}
    <div class="hub-prevnext" aria-label="Hub navigation">
      {% if prevHub %}
      <a href="{{ prevHub.url }}" class="hub-prevnext-link">
        <span class="hub-prevnext-arrow" aria-hidden="true">←</span>
        <span class="hub-prevnext-label">Previous</span>
        <span class="hub-prevnext-title">{{ prevHub.title }}</span>
      </a>
      {% else %}
      <span></span>
      {% endif %}
      {% if nextHub %}
      <a href="{{ nextHub.url }}" class="hub-prevnext-link is-next">
        <span class="hub-prevnext-title">{{ nextHub.title }}</span>
        <span class="hub-prevnext-label">Next</span>
        <span class="hub-prevnext-arrow" aria-hidden="true">→</span>
      </a>
      {% endif %}
    </div>
    {% endif %}

    {# ── Category columns ──────────────────────────────────────── #}
    <section class="hub-categories" style="grid-template-columns: repeat({{ categories | length }}, 1fr)">
      {% for cat in categories %}
      <article class="hub-cat-col">
        <h2 class="hub-cat-title">{{ cat.title }}</h2>
        <p class="hub-cat-desc">{{ cat.description }}</p>
        <a href="/{{ hubSlug }}/{{ cat.slug }}/" class="hub-cat-browse">Browse all {{ cat.title | lower }} →</a>
        <div class="hub-cat-recent-head">
          <p class="hub-eyebrow hub-eyebrow--small">Recent in this section</p>
        </div>
        <ul class="hub-cat-recent-list" role="list">
          {% for item in cat.recent %}
          <li class="hub-cat-recent-item">
            <a href="{{ item.url or '#' }}" class="hub-cat-recent-link">
              <div class="hub-cat-recent-meta">
                <span class="hub-cat-recent-type{% if item.kind == 'new' %} is-accent{% endif %}">{{ item.type }}</span>
                <span class="hub-cat-recent-date">{{ item.date }}</span>
              </div>
              <div class="hub-cat-recent-title{% if item.italic %} is-italic{% endif %}">{{ item.title }}</div>
            </a>
          </li>
          {% endfor %}
        </ul>
      </article>
      {% endfor %}
    </section>

    {# ── Recently filed feed ───────────────────────────────────── #}
    {% if feed and feed | length %}
    <section class="hub-feed">
      <div class="hub-feed-header">
        <h2 class="hub-feed-heading">Recently filed in {{ title }}</h2>
        <a href="#" class="hub-feed-all">All updates →</a>
      </div>
      {% for row in feed %}
      <a href="{{ row.url or '#' }}" class="hub-feed-row{% if row.kind == 'new' %} is-new{% endif %}">
        <span class="hub-feed-date">{{ row.date }}</span>
        <span class="hub-feed-type{% if row.kind == 'new' %} is-accent{% endif %}">{{ row.type }}</span>
        <span class="hub-feed-content">
          <span class="hub-feed-title{% if row.italic %} is-italic{% endif %}">{{ row.title }}</span>
          {% if row.summary %}<span class="hub-feed-summary">{{ row.summary }}</span>{% endif %}
        </span>
        <span class="hub-feed-arrow" aria-hidden="true">→</span>
      </a>
      {% endfor %}
    </section>
    {% endif %}

    {# ── Closing navigation ────────────────────────────────────── #}
    <section class="hub-close-nav">
      <p class="hub-eyebrow">Continue browsing</p>
      <div class="hub-close-links">
        {% if prevHub %}
        <a href="{{ prevHub.url }}" class="hub-close-link">
          <span class="hub-close-dir">← Previous section</span>
          <span class="hub-close-title">{{ prevHub.title }}</span>
        </a>
        {% endif %}
        <span class="hub-close-sep" aria-hidden="true"></span>
        {% if nextHub %}
        <a href="{{ nextHub.url }}" class="hub-close-link is-right">
          <span class="hub-close-dir">Next section →</span>
          <span class="hub-close-title">{{ nextHub.title }}</span>
        </a>
        {% endif %}
      </div>
    </section>

  </div>

  <!-- Search dropdown -->
  <div id="search-dropdown" class="search-dropdown" hidden>
    <div id="search"></div>
  </div>

  {% include "footer.njk" %}

  <script src="/pagefind/pagefind-ui.js"></script>
  <script src="/assets/site.js"></script>

</body>
</html>
