---
layout: base.njk
---

{# ── Hero ────────────────────────────────────────────────────────────── #}
<section class="home-hero-section">
  <div class="home-hero-main">
    <p class="home-eyebrow">Issue 07 &middot; Early access</p>
    <h1 class="home-headline">A working library<br>for <em>general practice</em>.</h1>
    <p class="home-lede">Guidelines, medications, calculators, and patient handouts, alongside essays and experiments from the edge of the consult. One GP&#8217;s hyperfixation project, now with a domain name.</p>
  </div>

  <aside class="home-hero-aside">
    <p class="home-eyebrow">This week</p>
    <ul class="this-week-list">
      {% set recentItems = collections.all | reverse %}
      {% set weekCount = 0 %}
      {% for item in recentItems %}
        {% if weekCount < 3 and item.url != "/" and item.data.title %}
          <li class="this-week-item">
            <time class="this-week-date" datetime="{{ item.date | dateISO }}">{{ item.date | dateDisplay }}</time>
            <a href="{{ item.url }}" class="this-week-title">{{ item.data.title }}</a>
          </li>
          {% set weekCount = weekCount + 1 %}
        {% endif %}
      {% endfor %}
    </ul>
  </aside>
</section>

{# ── Three Hubs ──────────────────────────────────────────────────────── #}
<section class="home-hubs-section">
  <div class="home-hubs-header">
    <p class="home-eyebrow">The three drawers</p>
    <p class="home-hubs-hint">start anywhere</p>
  </div>

  <div class="home-hubs-row">

    <div class="hub-card">
      <div class="hub-card-header">
        <p class="hub-card-eyebrow">Clinician Tools</p>
        <span class="hub-card-count">142 entries</span>
      </div>
      <h2 class="hub-card-title">Reference material for practice.</h2>
      <p class="hub-card-lede">Guidelines, medications, and clinical calculators, written for the GP at 10pm rather than the medical student.</p>
      <ul class="hub-card-list">
        <li><span class="hub-card-list-name">Topics</span><span class="hub-card-list-count">64</span></li>
        <li><span class="hub-card-list-name">Guidelines</span><span class="hub-card-list-count">38</span></li>
        <li><span class="hub-card-list-name">Medications</span><span class="hub-card-list-count">27</span></li>
        <li><span class="hub-card-list-name">Calculators</span><span class="hub-card-list-count">13</span></li>
      </ul>
      <a href="/clinician-tools/" class="hub-card-browse">Browse clinician tools &rarr;</a>
    </div>

    <div class="hub-card">
      <div class="hub-card-header">
        <p class="hub-card-eyebrow">Patient Tools</p>
        <span class="hub-card-count">46 entries</span>
      </div>
      <h2 class="hub-card-title">For the conversation in the room.</h2>
      <p class="hub-card-lede">Interactive explainers and printable handouts to share with the person across the desk.</p>
      <ul class="hub-card-list">
        <li><span class="hub-card-list-name">Explainers</span><span class="hub-card-list-count">21</span></li>
        <li><span class="hub-card-list-name">Handouts</span><span class="hub-card-list-count">25</span></li>
      </ul>
      <a href="/patient-tools/" class="hub-card-browse">Browse patient tools &rarr;</a>
    </div>

    <div class="hub-card">
      <div class="hub-card-header">
        <p class="hub-card-eyebrow">Beyond the Clinic</p>
        <span class="hub-card-count">29 entries</span>
      </div>
      <h2 class="hub-card-title">Thinking space for practice.</h2>
      <p class="hub-card-lede">Essays, experiments, and a quietly accumulating resource list, for the parts of the work that aren&#8217;t in the algorithm.</p>
      <ul class="hub-card-list">
        <li><span class="hub-card-list-name">Essays</span><span class="hub-card-list-count">18</span></li>
        <li><span class="hub-card-list-name">Resources</span><span class="hub-card-list-count">11</span></li>
      </ul>
      <a href="/beyond-the-clinic/" class="hub-card-browse">Browse beyond the clinic &rarr;</a>
    </div>

  </div>
</section>

{# ── Recently Updated ────────────────────────────────────────────────── #}
<section class="home-updates-section">
  <div class="home-updates-header">
    <h2 class="home-updates-heading">Recently updated</h2>
    <a href="/topics/" class="home-updates-all">All updates &rarr;</a>
  </div>

  {% set recentAll = collections.all | reverse %}
  {% set updateCount = 0 %}
  {% for item in recentAll %}
    {% if updateCount < 5 and item.url != "/" and item.data.title %}
      <a href="{{ item.url }}" class="update-row">
        <time class="update-date" datetime="{{ item.date | dateISO }}">{{ item.date | dateDisplay }}</time>
        <span class="update-type{% if updateCount == 0 %} is-accent{% endif %}">
          {%- if item.data.specialty -%}
            {{ item.data.specialty | capitalize }}
          {%- elif item.data.pageType -%}
            {{ item.data.pageType | capitalize }}
          {%- else -%}
            Topic
          {%- endif -%}
        </span>
        <div class="update-content">
          <span class="update-title">{{ item.data.title }}</span>
          {% if item.data.dek %}<p class="update-summary">{{ item.data.dek }}</p>{% endif %}
        </div>
        <span class="update-arrow" aria-hidden="true">&rarr;</span>
      </a>
      {% set updateCount = updateCount + 1 %}
    {% endif %}
  {% endfor %}
</section>
